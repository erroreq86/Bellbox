<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Portholes — One-Time Migration (JSONBin → Firestore)</title>
<style>
  *{box-sizing:border-box;}
  body{
    background:#060e1c;color:#e8f0f8;font-family:'Courier New',monospace;
    max-width:720px;margin:0 auto;padding:32px 20px 80px;line-height:1.6;
  }
  h1{font-size:1.3rem;color:#fff;margin-bottom:6px;}
  p.sub{color:#a8c0d8;font-size:.85rem;margin-bottom:24px;}
  .warn{
    background:rgba(212,176,74,.08);border:1px solid rgba(212,176,74,.3);
    border-radius:8px;padding:14px 16px;font-size:.82rem;color:#e8c96a;margin-bottom:24px;
  }
  button{
    background:#d4b04a;color:#060e1c;border:none;border-radius:8px;
    padding:12px 24px;font-weight:700;font-size:.85rem;cursor:pointer;
    font-family:inherit;
  }
  button:disabled{opacity:.4;cursor:not-allowed;}
  button:hover:not(:disabled){background:#e8c96a;}
  #log{
    margin-top:24px;background:#0b1527;border:1px solid #1a3050;border-radius:8px;
    padding:16px;font-size:.78rem;max-height:520px;overflow-y:auto;white-space:pre-wrap;
  }
  .ok{color:#6ee7b7;}
  .err{color:#f4a0a0;}
  .info{color:#a8c0d8;}
  .head{color:#e8c96a;font-weight:700;}
</style>
</head>
<body>
  <h1>Portholes — One-Time Data Migration</h1>
  <p class="sub">Copies your crew roster and all four test leaderboards from JSONBin into Firestore. Safe to run more than once — it won't create duplicates or overwrite a higher score with a lower one.</p>
  <div class="warn">Run this once, from a browser, while signed in to nothing else. It writes directly to your <code>portholes-6654a</code> Firestore project. Close this tab when it says "Migration complete."</div>
  <button id="startBtn" onclick="runMigration()">Start Migration</button>
  <div id="log"></div>

<script type="module">
import { initializeApp } from 'https://www.gstatic.com/firebasejs/12.15.0/firebase-app.js';
import { getAuth, signInAnonymously, onAuthStateChanged } from 'https://www.gstatic.com/firebasejs/12.15.0/firebase-auth.js';
import { getFirestore, doc, getDoc, setDoc, writeBatch } from 'https://www.gstatic.com/firebasejs/12.15.0/firebase-firestore.js';

const firebaseConfig = {
  apiKey: "AIzaSyDNtUZf28HhEEeaOirQvWUauIuSY3awgQY",
  authDomain: "portholes-6654a.firebaseapp.com",
  projectId: "portholes-6654a",
  storageBucket: "portholes-6654a.firebasestorage.app",
  messagingSenderId: "437900256359",
  appId: "1:437900256359:web:fc0412985f6f805e68e0c2",
  measurementId: "G-3X9P16H7Z6"
};
const fbApp = initializeApp(firebaseConfig);
const fbAuth = getAuth(fbApp);
const db = getFirestore(fbApp);
const authReady = new Promise((resolve, reject) => {
  onAuthStateChanged(fbAuth, (user) => { if (user) resolve(user); });
  signInAnonymously(fbAuth).catch(reject);
});

// ── Old JSONBin config (source) ──────────────────────────────────
const JB_API  = "https://api.jsonbin.io/v3";
const JB_KEY  = "$2a$10$8lAKv7F4JkE.wqwc.gAjQOLhm8MLiX7Von1XPYo4UhdHGgYUCdkDm";
const BIN_ROSTER = "6a40decfda38895dfe0ab4be";
const BINS = { t1:"6a3b7210da38895dfef59f58", t2:"6a40c8aada38895dfe0a700d", t3:"6a437233da38895dfe1476c2", t4:"6a44072cf5f4af5e294907b8" };
const TEST_COLLECTIONS = { t1:'scores_t1', t2:'scores_t2', t3:'scores_t3', t4:'scores_t4' };
const TEST_LABELS = { t1:'USPH Public Health', t2:'Food Safety', t3:'Product Knowledge', t4:'Product Knowledge B' };

const logEl = document.getElementById('log');
function log(msg, cls){
  const line = document.createElement('div');
  if (cls) line.className = cls;
  line.textContent = msg;
  logEl.appendChild(line);
  logEl.scrollTop = logEl.scrollHeight;
}

async function jbRead(bin){
  const r = await fetch(`${JB_API}/b/${bin}/latest`, { headers: { "X-Master-Key": JB_KEY, "X-Bin-Meta": "false" } });
  if (!r.ok) throw new Error(`JSONBin read failed (${r.status})`);
  const d = await r.json();
  return d.record || d;
}

window.runMigration = async function(){
  document.getElementById('startBtn').disabled = true;
  log('Starting migration…', 'head');

  try {
    await authReady;
    log('Signed in to Firebase anonymously.', 'ok');
  } catch (e) {
    log('Firebase sign-in failed — check your Firestore rules allow anonymous auth. ' + e.message, 'err');
    return;
  }

  // ── 1. Roster ──────────────────────────────────────────────────
  log('', null);
  log('Roster', 'head');
  try {
    const rosterData = await jbRead(BIN_ROSTER);
    const crew = rosterData.crew || {};
    const ids = Object.keys(crew);
    if (!ids.length) {
      log('No roster found in JSONBin — skipping (Firestore roster stays as-is).', 'info');
    } else {
      const batch = writeBatch(db);
      ids.forEach(id => batch.set(doc(db, 'crew', id), { name: crew[id] }));
      await batch.commit();
      log(`Imported ${ids.length} crew members.`, 'ok');
    }
  } catch (e) {
    log('Roster import failed: ' + e.message, 'err');
  }

  // ── 2. Scores, per test ───────────────────────────────────────
  for (const key of ['t1','t2','t3','t4']) {
    log('', null);
    log(`${TEST_LABELS[key]}`, 'head');
    try {
      const data = await jbRead(BINS[key]);
      const scores = data.scores || [];
      if (!scores.length) {
        log('No scores found — skipping.', 'info');
        continue;
      }
      let imported = 0, skipped = 0;
      for (const entry of scores) {
        if (!entry.id) { skipped++; continue; }
        const ref = doc(db, TEST_COLLECTIONS[key], String(entry.id));
        const existingSnap = await getDoc(ref);
        const existing = existingSnap.exists() ? existingSnap.data() : null;
        const isBetter = !existing
          || entry.score > existing.score
          || (entry.score === existing.score && (entry.time || Infinity) < (existing.time || Infinity));
        const finalEntry = {
          name: entry.name || (existing && existing.name) || 'Unknown',
          score: isBetter ? entry.score : existing.score,
          correct: isBetter ? (entry.correct ?? null) : (existing.correct ?? null),
          total: isBetter ? (entry.total ?? null) : (existing.total ?? null),
          time: isBetter ? (entry.time ?? existing?.time ?? null) : (existing.time ?? null),
          date: isBetter ? (entry.date || existing?.date || '') : (existing.date || ''),
          attempts: (existing?.attempts || 0) + 1
        };
        await setDoc(ref, finalEntry);
        imported++;
      }
      log(`Imported ${imported} score${imported===1?'':'s'}${skipped?`, skipped ${skipped} (missing crew ID)`:''}.`, 'ok');
    } catch (e) {
      log(`${TEST_LABELS[key]} import failed: ` + e.message, 'err');
    }
  }

  log('', null);
  log('Migration complete. You can close this tab.', 'head');
};
</script>
</body>
</html>
